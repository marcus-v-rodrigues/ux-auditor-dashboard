# ============================================
# Configuração do NextAuth.js (v5)
# ============================================
# URL base do aplicativo (usada para redirecionamentos e callbacks)
# IMPORTANTE: Use a porta onde o Next.js está rodando (padrão: 3001)
AUTH_URL=http://localhost:3001

# Segredo usado para criptografar cookies de sessão
# Gere um novo valor usando: openssl rand -base64 32
AUTH_SECRET=seu-secret-key-aqui-gerado-com-openssl-rand-base64-32

# ============================================
# Configuração OAuth2 do Janus IDP
# ============================================
# URL pública do issuer OIDC do Janus IDP
# Esta URL é usada pelo navegador do usuário para acessar o endpoint de autorização
# Em ambiente Docker, use o domínio público da VPS
AUTH_ISSUER_URL=http://localhost:3000/oidc

# URL interna para comunicação servidor-servidor no Docker (OBRIGATÓRIA em ambiente Docker)
# Esta URL é usada pelo backend para troca de tokens, userinfo e validação JWKS
# Quando rodando em containers Docker, o backend não consegue resolver "localhost"
# do host, então usamos o nome do serviço na rede Docker interna.
# Em desenvolvimento local sem Docker, deixe comentada (usa AUTH_ISSUER_URL)
AUTH_JANUS_INTERNAL_URL=http://janus-service:3000/oidc

# Client ID registrado no Janus IDP
AUTH_CLIENT_ID=ux-auditor

# Client Secret registrado no Janus IDP
AUTH_CLIENT_SECRET=janus_dashboard_secret

# Escopos OAuth2 solicitados
# - openid: Obrigatório para OIDC
# - profile: Permite acesso ao perfil do usuário (nome, etc)
# - email: Permite acesso ao email do usuário
# - offline_access: Permite obter refresh_token para renovação de token
AUTH_SCOPE=openid profile email offline_access

# Resource indicator enviado na authorization request.
# Define explicitamente o audience (`aud`) do access token JWT emitido pelo Janus.
AUTH_RESOURCE=http://localhost:8000

# ============================================
# Configuração da API de Backend
# ============================================
# URL base da API do UX Auditor
UX_AUDITOR_API_URL=http://localhost:8000

# ============================================
# Notas sobre PKCE (Proof Key for Code Exchange)
# ============================================
# O NextAuth.js v5 implementa PKCE automaticamente quando configurado
# corretamente. O fluxo PKCE funciona da seguinte forma:
#
# 1. Geração de code_verifier:
#    - String aleatória de 43-128 caracteres
#    - Gerada automaticamente pelo NextAuth.js
#
# 2. Geração de code_challenge:
#    - Hash SHA256 do code_verifier
#    - Codificado em base64url
#    - Gerado automaticamente pelo NextAuth.js
#
# 3. Redirecionamento para autorização:
#    - URL: http://localhost:3000/oidc/auth
#    - Parâmetros:
#      * response_type=code
#      * client_id=ux-auditor
#      * redirect_uri=http://localhost:3001/api/auth/callback/janus
#      * scope=openid profile email offline_access
#      * resource=ux-auditor-api
#      * code_challenge=<hash gerado>
#      * code_challenge_method=S256
#      * state=<random string>
#
# 4. Callback no endpoint de token:
#    - URL: http://localhost:3000/oidc/token
#    - Parâmetros:
#      * grant_type=authorization_code
#      * code=<código recebido no callback>
#      * redirect_uri=http://localhost:3001/api/auth/callback/janus
#      * client_id=ux-auditor
#      * client_secret=janus_dashboard_secret
#      * code_verifier=<string gerada no passo 1>
#
# 5. Resposta com tokens:
#    - access_token: Token para acessar recursos protegidos
#    - refresh_token: Token para renovar o access_token (se offline_access foi solicitado)
#    - expires_in: Tempo de expiração em segundos
#    - token_type: Geralmente "Bearer"

# ============================================
# Instruções de Configuração
# ============================================
# 1. Copie este arquivo para .env.local:
#    cp .env.example .env.local
#
# 2. Gere um AUTH_SECRET único:
#    openssl rand -base64 32
#
# 3. Configure as URLs conforme seu ambiente:
#    - Desenvolvimento local: use localhost
#    - Docker: use nomes de serviço para comunicação interna
#    - Produção: use domínios públicos com HTTPS
#
# 4. Registre o callback URL no Janus IDP:
#    http://localhost:3001/api/auth/callback/janus
#
# 5. Reinicie o servidor de desenvolvimento:
#    npm run dev
